{
  "version": 2,
  "builds": [
    { "src": "api/**/*.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/health", "dest": "/api/health.js" },
    { "src": "/api/check", "dest": "/api/check.js" },
    { "src": "/api/signals", "dest": "/api/signals.js" }
  ],
  "crons": [
    {
      "path": "/api/check?tier=1",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/check?tier=2",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/check?tier=3",
      "schedule": "0 */4 * * *"
    }
  ]
}
